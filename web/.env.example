# Hunchproof web — environment
#
# Point the app at a running Hunchproof backend (pof_backend.py / deployed FastAPI).
# Leave this UNSET to run in self-contained demo mode (synthetic data, clearly labeled).
#
# The app also accepts an override at runtime via ?api=<url> or window.POF_API_BASE,
# which takes precedence over this build-time value (handy for one-off demos).
VITE_API_BASE=http://127.0.0.1:8000
